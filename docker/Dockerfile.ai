FROM freqtradeorg/freqtrade:develop

# Document required environment variables
ENV GEMINI_API_KEY="" \
    GROQ_API_KEY="" \
    OPENROUTER_API_KEY="" \
    AI_DB_PATH="/freqtrade/user_data/db/ai_data.sqlite" \
    CHROMA_PERSIST_DIR="/freqtrade/user_data/db/vectordb"

# Switch to root temporarily if needed for permissions, but Freqtrade base normally handles user pip
# AI dependencies
COPY --chown=ftuser:ftuser requirements-ai.txt /freqtrade/
RUN pip install --user --no-cache-dir -r /freqtrade/requirements-ai.txt

# AI scripts
COPY --chown=ftuser:ftuser user_data/scripts/ /freqtrade/user_data/scripts/

# Download ML models on build
RUN python /freqtrade/user_data/scripts/download_models.py

# Restore user context just to be explicit (preserves base image settings)
USER ftuser

# Healthcheck to verify the bot is alive
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8080/api/v1/ping || exit 1
