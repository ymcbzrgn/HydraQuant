{
    "dry_run": false,
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "testnet": true,
    "stake_currency": "USDT",
    "stake_amount": "unlimited",
    "max_open_trades": 20,
    "entry_pricing": {
        "price_side": "other",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exit_pricing": {
        "price_side": "other",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exchange": {
        "name": "binance",
        "key": "env:BINANCE_TESTNET_KEY",
        "secret": "env:BINANCE_TESTNET_SECRET",
        "ccxt_config": {
            "urls": {
                "api": {
                    "fapiPublic": "https://testnet.binancefuture.com/fapi",
                    "fapiPrivate": "https://testnet.binancefuture.com/fapi"
                }
            },
            "options": {
                "defaultType": "future"
            }
        },
        "ccxt_sync_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [],
        "pair_blacklist": [
            "(BULL|BEAR|UP|DOWN|HALF|HEDGE)/.*",
            ".*(BUSD|TUSD|FDUSD).*"
        ]
    },
    "pairlists": [
        {
            "method": "VolumePairList",
            "number_assets": 100,
            "sort_key": "quoteVolume",
            "min_value": 0,
            "refresh_period": 1800
        },
        {
            "method": "PriceFilter",
            "low_price_ratio": 0.001
        },
        {
            "method": "SpreadFilter",
            "max_spread_ratio": 0.01
        }
    ],
    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 8080,
        "verbosity": "error",
        "jwt_secret_key": "freqtrade-ai-2026-secret-key",
        "CORS_origins": ["*"],
        "username": "freqtrader",
        "password": "SuperSecurePassword"
    },
    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": ""
    },
    "initial_state": "running",
    "force_entry_enable": false
}
